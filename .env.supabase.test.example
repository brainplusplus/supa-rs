# .env.supabase.test.example — Supabase alias style for compat testing
# DO NOT copy values from here — run: node scripts/gen-env-test.mjs
# Used with: suparust start --profile supabase.test
#
# This file tests the SupaRust env compat layer end-to-end using Supabase-style
# alias vars (JWT_SECRET, ANON_KEY, PORT, etc.) instead of SUPARUST_* canonical vars.
#
# Profile identity: supabase.test → PID: .suparust.profile.supabase.test.53002.pid
# Isolation: --profile supabase.test loads ONLY this file (.env is never loaded)

SUPARUST_ENV=compat
PORT=53002
JWT_SECRET=<generated>
ANON_KEY=<generated>
SERVICE_ROLE_KEY=<generated>
DATA_DIR=./data/pg-compat
STORAGE_ROOT=./data/storage-compat
